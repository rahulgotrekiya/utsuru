# Utsuru Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server
PORT=4096
HOST=0.0.0.0

# Security
# Generate a strong secret: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-string-use-openssl-rand-hex-32
ADMIN_PASSWORD=change-me

# Media Paths
# Use absolute paths — Node.js does not expand ~
MEDIA_MOVIES_DIR=/media/movies
MEDIA_TV_DIR=/media/tv

# aria2c RPC
ARIA2_RPC_URL=http://localhost:6800/jsonrpc
ARIA2_RPC_SECRET=

# Jellyfin (optional)
JELLYFIN_URL=
JELLYFIN_API_KEY=

# Database
DATABASE_PATH=./data/utsuru.db

# Timezone
TZ=UTC
